rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isActive() {
      return true; // Allowing access for "EZ" mode without Auth
    }

    function isOwner(data, targetUserId) {
      return data.userId == targetUserId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // ... (rest of the file helpers remain similar but without request.auth)

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'date', 'amount', 'type', 'category', 'description', 'account']) &&
             data.userId is string &&
             data.date is string &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             data.category is string;
    }

    // Rules Mapping - Simple Privacy (By User ID field)
    
    match /users/{userId} {
      allow read, write: if true;
    }

    match /transactions/{id} {
      allow read, write: if true;
    }

    match /stocks/{id} {
      allow read, write: if true;
    }

    match /stockTransactions/{id} {
      allow read, write: if true;
    }

    match /savingsGoals/{id} {
      allow read, write: if true;
    }

    match /reminders/{id} {
      allow read, write: if true;
    }

    match /recurring/{id} {
      allow read, write: if true;
    }
  }
}
